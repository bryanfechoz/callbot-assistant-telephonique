# ─────────────────────────────────────────────
# CONFIGURATION ASSISTANTPRO WEBHOOK
# Copie ce fichier en .env et remplis les valeurs
# ─────────────────────────────────────────────

# Port du serveur (Railway/Render le définissent automatiquement)
PORT=3000

# Fuseau horaire
TIMEZONE=Europe/Paris

# ─── Google Calendar (Service Account) ───────
# Récupère ces valeurs dans le JSON téléchargé depuis Google Cloud Console
GOOGLE_PROJECT_ID=mon-projet-google
GOOGLE_PRIVATE_KEY_ID=abc123def456
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_CLIENT_EMAIL=assistantpro@mon-projet.iam.gserviceaccount.com
GOOGLE_CLIENT_ID=123456789012345678901

# ID du calendrier cible (laisser "primary" pour le calendrier principal)
# Pour un calendrier dédié : récupère l'ID dans Paramètres Google Calendar
GOOGLE_CALENDAR_ID=primary

# ─── Sécurité ElevenLabs ──────────────────────
# Secret partagé pour vérifier que les appels viennent bien d'ElevenLabs
# Définis une valeur aléatoire et renseigne-la aussi dans ElevenLabs
ELEVENLABS_WEBHOOK_SECRET=ton_secret_aleatoire_ici
